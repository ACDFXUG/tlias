<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.tlias.mapper.ClazzMapper"> 

    <!-- list --> 

    <select id="list" resultType="com.example.tlias.pojo.Clazz">
        select * from clazz
        <where>
            <if test="name!=null and name!=''">and name like concat('%',#{name},'%')</if>
            <if test='begin!=null'> and begin_date &gt;= #{begin}</if>
            <if test='end!=null'> and end_date &lt;= #{end}</if>
        </where>
    </select>

    <!-- add --> 

    <insert id="add">
        insert into clazz(name,room,begin_date,end_date,,master_id,subject)
        values(#{name},#{room},#{beginDate},#{endDate},#{masterId},#{subject})
    </insert>

    <!-- update --> 

    <update id="update">
        update clazz
        <set>
            <if test="name!=null">name=#{name},</if>
            <if test="room!=null">room=#{room},</if>
            <if test="beginDate!=null">begin_date=#{beginDate},</if>
            <if test="endDate!=null">end_date=#{endDate},</if>
            <if test="masterId!=null">master_id=#{masterId},</if>
            <if test="subject!=null">subject=#{subject},</if>
        </set>
    </update>
</mapper>